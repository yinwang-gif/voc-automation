{
  "data_sources": {
    "tickets": {
      "enabled": true,
      "api_endpoint": "mock://tickets",
      "auth_token": "",
      "days_lookback": 8
    },
    "telegram": {
      "enabled": true,
      "api_endpoint": "mock://telegram",
      "channel_id": "test-channel",
      "days_lookback": 8
    },
    "langfuse": {
      "enabled": true,
      "api_endpoint": "mock://langfuse",
      "project_id": "test-project",
      "days_lookback": 8
    }
  },
  "analysis": {
    "claude_model": "claude-sonnet-4-6",
    "max_tokens": 16000,
    "use_prompt_caching": true,
    "mock_analysis": true,
    "product_decision": {
      "enabled": true,
      "apply_to_priorities": ["P0", "P1"]
    }
  },
  "phabricator": {
    "base_url": "https://pha.1cobo.com",
    "use_mcp": true,
    "auto_create_tasks": true,
    "priority_threshold": "P0/P1"
  },
  "output": {
    "report_dir": "/tmp/voc-automation-output",
    "report_format": ["markdown", "excel"]
  },
  "schedule": {
    "cron": "0 9 * * 1",
    "description": "Weekly VOC analysis test run"
  }
}
